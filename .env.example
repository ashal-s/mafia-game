# Supabase — find these in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use either name (Vercel's Supabase integration sets ANON_KEY):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service-role key (server-only secret). Required for phase auto-advance and Web Push.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_service_role_jwt

# Cron auth. Must match the `cron_secret` value in Supabase Vault (see below).
CRON_SECRET=generate-a-long-random-string

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@yourdomain.com

# --- Supabase Vault (phase auto-advance cron) ---
# Phase auto-advance is scheduled in Supabase (pg_cron), not Vercel Cron.
# After deploying, add these secrets in Supabase → SQL Editor:
#
#   select vault.create_secret(
#     'https://YOUR-APP.vercel.app/api/cron/advance-phases',
#     'advance_phases_url',
#     'Phase auto-advance endpoint'
#   );
#   select vault.create_secret(
#     'YOUR_CRON_SECRET',
#     'cron_secret',
#     'Must match CRON_SECRET above'
#   );
