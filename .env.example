# Supabase — find these in your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Use either name (Vercel's Supabase integration sets ANON_KEY):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service-role key (server-only secret). Required for the phase auto-advance
# cron and for sending Web Push. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_service_role_jwt

# Vercel Cron auth. Set the same value as a Vercel env var; Vercel sends it as
# `Authorization: Bearer <CRON_SECRET>` to /api/cron/advance-phases.
CRON_SECRET=generate-a-long-random-string

# Web Push (VAPID). Generate a key pair once with:
#   npx web-push generate-vapid-keys
# The public key is safe to expose; the private key is a server-only secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent with push (mailto: or https:). Optional but recommended.
VAPID_SUBJECT=mailto:notifications@yourdomain.com
